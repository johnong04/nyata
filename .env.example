# Copy to .env.local and fill. .env.local is gitignored — never commit real keys.

# --- Supabase (D2+): Project Settings → API ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=   # sb_publishable_... (safe for client)
SUPABASE_SECRET_KEY=                     # sb_secret_... server-only (scraper/service writes past RLS)

# --- AI: Google AI Studio (D2) — one key covers OCR + verdict ---
GOOGLE_GENERATIVE_AI_API_KEY=            # model: gemini-2.5-flash (vision + generateObject)

# --- 21st.dev Magic MCP (UI generation) — set in shell env, not committed ---
MAGIC_API_KEY=                           # from 21st.dev Magic Console

